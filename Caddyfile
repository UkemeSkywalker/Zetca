# With a custom domain (automatic HTTPS):
#   Set DOMAIN=yourdomain.com in your .env.local
#   Caddy will auto-provision a Let's Encrypt cert
#
# Without a domain (IP-only access, HTTP only):
#   Leave DOMAIN unset or set DOMAIN=:80
#   Access via http://<your-lightsail-ip>

{$DOMAIN::80} {
    # Python backend API routes
    handle /api/strategy/* {
        reverse_proxy backend:8000
    }
    handle /api/copy/* {
        reverse_proxy backend:8000
    }
    handle /api/scheduler/* {
        reverse_proxy backend:8000
    }
    handle /api/publisher/* {
        reverse_proxy backend:8000
    }

    # Everything else goes to Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }

    # Compression
    encode gzip zstd

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Logging
    log {
        output stdout
        format console
    }
}
