# Authentication Configuration
# Generate a secure random string for production (e.g., using: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS DynamoDB Configuration
# Table name should match the Terraform output (users-{environment})
DYNAMODB_TABLE_NAME=users-dev

# AWS Region where DynamoDB table is provisioned
AWS_REGION=us-east-1

# AWS Credentials (if not using IAM roles)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# LinkedIn OAuth 2.0 Configuration
# Create a LinkedIn App at https://www.linkedin.com/developers/apps
# Enable "Sign In with LinkedIn using OpenID Connect" and "Share on LinkedIn" products
# Add your redirect URI under Auth > OAuth 2.0 settings
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback
