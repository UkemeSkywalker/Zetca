# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Configuration
DYNAMODB_USERS_TABLE=users-dev
DYNAMODB_STRATEGIES_TABLE=strategies-dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Bedrock Configuration
# Available active models: claude-sonnet-4-6, claude-haiku-4-5-20251001-v1:0, claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# API Configuration
FRONTEND_URL=http://localhost:3000
API_PORT=8000

# Agent Configuration
# Set to true to use mock agent (no AWS required), false to use real Bedrock agent
USE_MOCK_AGENT=false

# Timeout Configuration
AGENT_TIMEOUT_SECONDS=60
